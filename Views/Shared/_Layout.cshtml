<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"] - Colo Shop</title>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description" content="Colo Shop Template">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <!-- Common CSS Stylesheets -->
    <link rel="stylesheet" type="text/css" href="/styles/bootstrap4/bootstrap.min.css" asp-append-version="true">
    <link href="/plugins/font-awesome-4.7.0/css/font-awesome.min.css" rel="stylesheet" type="text/css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/plugins/OwlCarousel2-2.2.1/owl.carousel.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/plugins/OwlCarousel2-2.2.1/owl.theme.default.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="/plugins/OwlCarousel2-2.2.1/animate.css" asp-append-version="true">

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

<div class="super_container">

    <partial name="_HeaderPartial" />

    @RenderBody()

    <partial name="_FooterPartial" />

</div>

<!-- Common Scripts -->
<script src="/js/jquery-3.2.1.min.js" asp-append-version="true"></script>
<script src="/styles/bootstrap4/popper.js" asp-append-version="true"></script>
<script src="/styles/bootstrap4/bootstrap.min.js" asp-append-version="true"></script>
<script src="/plugins/Isotope/isotope.pkgd.min.js" asp-append-version="true"></script>
<script src="/plugins/OwlCarousel2-2.2.1/owl.carousel.js" asp-append-version="true"></script>
<script src="/plugins/easing/easing.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>